# Environment Configuration
# This file sets up environment variables for the portfolio

# Development Environment
# When running 'npm run dev' or 'yarn dev', Vite automatically sets:
# - VITE_MODE=development
# - import.meta.env.DEV=true
# - import.meta.env.PROD=false

# Production Environment  
# When running 'npm run build', Vite automatically sets:
# - VITE_MODE=production
# - import.meta.env.DEV=false
# - import.meta.env.PROD=true

# Custom environment variables (prefix with VITE_ to access in frontend)
